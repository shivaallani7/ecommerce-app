# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Azure SQL Database
DATABASE_URL=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=ecommerce;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Authentication=Active Directory Default
DB_SERVER=<server>.database.windows.net
DB_NAME=ecommerce
DB_USER=adminuser
DB_PASSWORD=<your-password>

# JWT
JWT_SECRET=<your-256-bit-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<your-refresh-256-bit-secret>
JWT_REFRESH_EXPIRES_IN=7d

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=product-images
AZURE_CDN_ENDPOINT=https://<cdn-endpoint>.azureedge.net

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
AZURE_CLIENT_ID=<client-id>
AZURE_CLIENT_SECRET=<client-secret>
AZURE_TENANT_ID=<tenant-id>

# Azure AD B2C
AAD_B2C_TENANT_NAME=<tenant-name>
AAD_B2C_CLIENT_ID=<b2c-client-id>
AAD_B2C_CLIENT_SECRET=<b2c-client-secret>
AAD_B2C_POLICY_NAME=B2C_1_signupsignin

# Redis (Azure Cache for Redis)
REDIS_CONNECTION_STRING=rediss://<name>.redis.cache.windows.net:6380
REDIS_PASSWORD=<redis-access-key>

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_<your-stripe-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://<your-frontend>.azurewebsites.net

# Email (optional - Azure Communication Services)
EMAIL_FROM=noreply@yourdomain.com
